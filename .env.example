# ── ABA PayWay ───────────────────────────────────────────────────────────────
# 复制为 .env 后填入真实凭证；切勿将 .env 提交到 Git。

# Sandbox 使用 1；Production 使用 0。未设置时默认 Sandbox。
PAYWAY_SANDBOX=1

# ABA PayWay 凭证（Sandbox/Production 分别使用对应环境的凭证）
PAYWAY_MERCHANT_ID=
PAYWAY_API_KEY=

# API 根地址（推荐根路径，代码会自动拼接 /payments/* 端点）
# Sandbox：https://checkout-sandbox.payway.com.kh/api/payment-gateway/v1
# Production：https://checkout.payway.com.kh/api/payment-gateway/v1
PAYWAY_API_URL=

# 前端公网地址，用于 PayWay return deeplink
PAYWAY_APP_PUBLIC_URL=https://your-frontend.example.com

# KHQR 有效期（分钟），默认 30
PAYWAY_QR_LIFETIME_MIN=30

# 可选：单独覆盖各端点 URL（一般无需设置）
# PAYWAY_CHECKOUT_URL=
# PAYWAY_CHECK_URL=
# PAYWAY_QR_URL=

# ── 服务 ────────────────────────────────────────────────────────────────────
PORT=8787
HOST=0.0.0.0

# 持久化数据目录（Railway Volume 挂载 /data）
PERSISTENT_DATA_DIR=./server/data

# Telegram Bot（生产环境建议配置以校验 initData）
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFY_CHAT_ID=

# 前端地址（PAYWAY_APP_PUBLIC_URL 未设置时的回退）
# APP_PUBLIC_URL=
